import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import seaborn as sns


def extract_text_driven_signals(filepath):
    # Step 1: Data Ingestion
    df = pd.read_csv(filepath)
    text_df = df.copy()

    # Step 2: Extract Text Length Dynamics (Headline Structural Profile)
    text_df["headline_word_count"] = (
        text_df["news_headline"].astype(str).apply(lambda x: len(x.split()))
    )

    # Step 3: Specific Financial Signal Division (Manual Token Mapping)
    # Hum text tokens ko positive aur negative impact vectors mein divide kar rahe hain
    negative_tokens = ["weak", "negative", "drop", "sell", "elevated", "risk"]
    positive_tokens = [
        "growth",
        "breakout",
        "buy",
        "positive",
        "strong",
        "momentum",
    ]

    # Reasoning text ko lower case karke specific keywords frequency count karna
    text_df["reasoning_clean"] = (
        text_df["agent_reasoning_summary"].astype(str).str.lower()
    )

    text_df["negative_sentiment_density"] = text_df["reasoning_clean"].apply(
        lambda x: sum(1 for token in negative_tokens if token in x)
    )

    text_df["positive_sentiment_density"] = text_df["reasoning_clean"].apply(
        lambda x: sum(1 for token in positive_tokens if token in x)
    )

    # Net Content Velocity Score
    text_df["net_text_signal_velocity"] = (
        text_df["positive_sentiment_density"]
        - text_df["negative_sentiment_density"]
    )

    # Step 4: Aggregate Statistical Analysis (Text Insights)
    # Check karte hain ki jab text signal net negative hota hai vs net positive hota hai, toh price changes kaise hote hain
    text_df["signal_category"] = np.where(
        text_df["net_text_signal_velocity"] > 0,
        "Bullish Text Flow",
        np.where(
            text_df["net_text_signal_velocity"] < 0,
            "Bearish Text Flow",
            "Neutral Text Flow",
        ),
    )

    text_analysis_summary = (
        text_df.groupby("signal_category")
        .agg(
            volume_records=("asset_symbol", "count"),
            avg_market_price_move=("market_price_change_pct", "mean"),
            avg_volatility_score=("volatility_score", "mean"),
            avg_headline_words=("headline_word_count", "mean"),
        )
        .reset_index()
    )

    print("=== TEXT-DRIVEN SIGNAL SEGMENTATION MATRIX ===")
    print(text_analysis_summary.to_string(index=False))

    # ----------------------------------------------------
    # PLOT 4: Text Signal Velocity vs Price Action Magnitude
    # ----------------------------------------------------
    plt.figure(figsize=(10, 5))
    sns.barplot(
        data=text_df,
        x="signal_category",
        y="market_price_change_pct",
        hue="news_impact_level",
        palette="magma",
    )
    plt.title(
        "Text Signal Segmentation: Impact of Agent Reasoning Flow on Price Change",
        fontsize=13,
        fontweight="bold",
    )
    plt.xlabel("Extracted Text Flow Category", fontsize=11)
    plt.ylabel("Average Market Price Change (%)", fontsize=11)
    plt.tight_layout()
    plt.savefig("text_signal_impact_matrix.png", dpi=300)
    plt.show()
    plt.close()

    return text_df, text_analysis_summary


# Pipeline execution call
processed_text_data, text_summary = extract_text_driven_signals("finsight_ai_market_signals_dataset.csv")
