import pandas as pd
import numpy as np
from sklearn.preprocessing import StandardScaler
from sklearn.cluster import KMeans

def engineer_market_regimes(filepath):
    # Step 1: Ingestion
    df = pd.read_csv(filepath)
    analysis_df = df.copy()
    
    # Step 2: Isolate pure market dynamics metrics for baseline scaling
    # We choose metrics completely independent of price tracking to prevent leakage
    regime_features = ['trading_volume_change_pct', 'volatility_score', 'social_media_buzz_score']
    
    scaler = StandardScaler()
    scaled_features = scaler.fit_transform(analysis_df[regime_features])
    
    # Step 3: KMeans Clustering to identify structural market regimes
    # Cluster 0: Quiet/Low Liquidity, Cluster 1: High Buzz/Speculative, Cluster 2: Institutional Volume Surge
    kmeans = KMeans(n_clusters=3, random_state=42, n_init=10)
    analysis_df['market_regime_cluster'] = kmeans.fit_predict(scaled_features)
    
    # Step 4: Re-encode text metrics with cluster scaling parameters
    analysis_df['regime_sentiment_impact'] = (
        analysis_df['news_sentiment_score'] * (analysis_df['market_regime_cluster'] + 1)
    )
    
    # Step 5: Statistical Distribution Breakdown per Cluster Regime
    regime_summary = analysis_df.groupby('market_regime_cluster').agg(
        record_count=('asset_symbol', 'count'),
        avg_price_change=('market_price_change_pct', 'mean'),
        avg_volatility=('volatility_score', 'mean'),
        avg_volume_change=('trading_volume_change_pct', 'mean'),
        avg_buzz=('social_media_buzz_score', 'mean')
    ).reset_index()
    
    print("=== ENGINEERED MARKET REGIME STRUCTURAL BREAKDOWN ===")
    print(regime_summary.to_string(index=False))
    
    return analysis_df, regime_summary

# Run the structural clustering script
clustered_data, regime_metrics = engineer_market_regimes("finsight_ai_market_signals_dataset.csv")
