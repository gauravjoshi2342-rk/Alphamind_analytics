import pandas as pd
import numpy as np
from sklearn.preprocessing import StandardScaler
from sklearn.cluster import KMeans

def execute_multimodal_agentic_system(filepath):
    # Step 1: Ingestion
    df = pd.read_csv(filepath)
    multimodal_df = df.copy()
    
    # Step 2: Unsupervised Structural Regime Extraction
    regime_features = ['trading_volume_change_pct', 'volatility_score', 'social_media_buzz_score']
    scaler = StandardScaler()
    scaled_features = scaler.fit_transform(multimodal_df[regime_features])
    
    kmeans = KMeans(n_clusters=3, random_state=42, n_init=10)
    multimodal_df['market_regime_cluster'] = kmeans.fit_predict(scaled_features)
    
    # Step 3: Text Density Token Extraction (Multimodal Bridge)
    negative_tokens = ['weak', 'negative', 'drop', 'sell', 'elevated', 'risk']
    positive_tokens = ['growth', 'breakout', 'buy', 'positive', 'strong', 'momentum']
    
    multimodal_df['reasoning_clean'] = multimodal_df['agent_reasoning_summary'].astype(str).str.lower()
    
    multimodal_df['neg_density'] = multimodal_df['reasoning_clean'].apply(lambda x: sum(1 for t in negative_tokens if t in x))
    multimodal_df['pos_density'] = multimodal_df['reasoning_clean'].apply(lambda x: sum(1 for t in positive_tokens if t in x))
    multimodal_df['net_text_velocity'] = multimodal_df['pos_density'] - multimodal_df['neg_density']
    
    # Step 4: Building the Intelligent Agentic Risk Score Matrix
    # Hum sentiment, market volatility aur text patterns ko fuse karke decision le rahe hain
    conditions = [
        (multimodal_df['market_regime_cluster'] == 0) & (multimodal_df['net_text_velocity'] >= 0) & (multimodal_df['news_sentiment_score'] > 0.2),
        (multimodal_df['market_regime_cluster'] == 2) | (multimodal_df['volatility_score'] > 60) | (multimodal_df['risk_label'].str.lower() == 'high'),
        (multimodal_df['net_text_velocity'] < 0) & (multimodal_df['news_sentiment_score'] < -0.2)
    ]
    
    choices = [
        'CONFIDENCE HIGH: PROCEED/EXECUTE',
        'ELEVATED RISK: HOLD POSITION/STAY CAUTIOUS',
        'CRITICAL RISK: MARKET PANIC/LIQUIDATE'
    ]
    
    # Default output agar koi condition trigger na ho (Neutral stance)
    multimodal_df['agentic_action_signal'] = np.select(conditions, choices, default='NEUTRAL MARKET: MONITOR TREND')
    
    # Step 5: Statistical Usability Report for Personal Finance Dashboard
    usability_summary = multimodal_df.groupby('agentic_action_signal').agg(
        total_signals=('asset_symbol', 'count'),
        avg_price_yield=('market_price_change_pct', 'mean'),
        avg_volatility=('volatility_score', 'mean'),
        avg_buzz_level=('social_media_buzz_score', 'mean')
    ).reset_index()
    
    print("=== MULTIMODAL INTELLIGENT AGENTIC DASHBOARD DATA ===")
    print(usability_summary.to_string(index=False))
    
    return multimodal_df, usability_summary

# Run the complete agentic intelligence script
final_agent_data, dashboard_metrics = execute_multimodal_agentic_system("finsight_ai_market_signals_dataset.csv")
