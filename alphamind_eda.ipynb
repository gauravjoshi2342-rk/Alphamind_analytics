import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import seaborn as sns
from sklearn.preprocessing import StandardScaler
from sklearn.cluster import KMeans

def run_alphamind_visual_eda(filepath):
    # Step 1: Ingestion and Clustering Setup
    df = pd.read_csv(filepath)
    eda_df = df.copy()
    
    regime_features = ['trading_volume_change_pct', 'volatility_score', 'social_media_buzz_score']
    scaler = StandardScaler()
    scaled_features = scaler.fit_transform(eda_df[regime_features])
    
    kmeans = KMeans(n_clusters=3, random_state=42, n_init=10)
    eda_df['market_regime_cluster'] = kmeans.fit_predict(scaled_features)
    
    # Step 2: Plot Formatting Settings (Professional Look)
    sns.set_theme(style="whitegrid")
    plt.rcParams['figure.figsize'] = [12, 6]
    plt.rcParams['font.size'] = 10
    
    # ----------------------------------------------------
    # PLOT 1: Multi-Dimensional Cluster Segmentation Map
    # ----------------------------------------------------
    plt.figure(figsize=(10, 6))
    sns.scatterplot(
        data=eda_df, 
        x='volatility_score', 
        y='trading_volume_change_pct', 
        hue='market_regime_cluster',
        palette='Set1',
        size='social_media_buzz_score',
        sizes=(20, 200),
        alpha=0.7
    )
    plt.title('AlphaMind Market Regimes: Volatility vs Volume vs Social Buzz', fontsize=14, fontweight='bold')
    plt.xlabel('Market Volatility Score', fontsize=12)
    plt.ylabel('Trading Volume Change (%)', fontsize=12)
    plt.legend(title='Market Cluster ID', bbox_to_anchor=(1.05, 1), loc='upper left')
    plt.tight_layout()
    plt.savefig('market_regime_clusters.png', dpi=300)
    plt.show()
    plt.close()
    
    # ----------------------------------------------------
    # PLOT 2: Sentiment Impact Matrix Across Different Clusters
    # ----------------------------------------------------
    plt.figure(figsize=(12, 5))
    sns.boxplot(
        data=eda_df,
        x='market_regime_cluster',
        y='market_price_change_pct',
        hue='signal_label',
        palette='deep'
    )
    plt.title('Price Change Distribution and Executed Signals Across Regimes', fontsize=14, fontweight='bold')
    plt.xlabel('Engineered Market Regime Cluster', fontsize=12)
    plt.ylabel('Market Price Change (%)', fontsize=12)
    plt.legend(title='Signal Bound')
    plt.tight_layout()
    plt.savefig('regime_price_distribution.png', dpi=300)
    plt.show()
    plt.close()
    
    # ----------------------------------------------------
    # PLOT 3: Selected Correlation Heatmap for Core Analytics
    # ----------------------------------------------------
    # Select only pure numerical indicators for correlation matrix mapping
    core_numeric_cols = [
        'news_sentiment_score', 'market_price_change_pct', 
        'trading_volume_change_pct', 'volatility_score', 
        'social_media_buzz_score', 'market_regime_cluster'
    ]
    corr_matrix = eda_df[core_numeric_cols].corr()
    
    plt.figure(figsize=(8, 6))
    sns.heatmap(corr_matrix, annot=True, cmap='coolwarm', fmt=".3f", linewidths=.5, square=True)
    plt.title('Core Metric Interaction Heatmap (AlphaMind Core)', fontsize=14, fontweight='bold')
    plt.tight_layout()
    plt.savefig('metric_correlation_matrix.png', dpi=300)
    plt.show()
    plt.close()
    
    print("=== EDA LOGS ===")
    print("All three production-grade visualization plots have been generated and saved to your directory.")
    
    return None

# Execute EDA generation script
run_alphamind_visual_eda("finsight_ai_market_signals_dataset.csv")
