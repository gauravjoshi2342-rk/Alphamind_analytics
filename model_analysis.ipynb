import pandas as pd
import numpy as np
from sklearn.model_selection import train_test_split
from sklearn.ensemble import RandomForestRegressor, RandomForestClassifier
from sklearn.metrics import r2_score, mean_absolute_error, classification_report


def run_alphamind_analytics(filepath):
    # Step 1: Data Ingestion and Validation
    df = pd.read_csv(filepath)
    
    # Step 2: Innovative Analyst Feature Engineering
    processed_df = df.copy()
    
    # Feature 1: Sentiment-Buzz Amplification Vector
    processed_df['sentiment_buzz_interaction'] = (
        processed_df['news_sentiment_score'] * processed_df['social_media_buzz_score']
    )
    
    # Feature 2: Market Momentum Friction (Price change normalized by volume change)
    # Adding a small epsilon (1e-5) to prevent division-by-zero anomalies
    processed_df['momentum_friction'] = (
        processed_df['market_price_change_pct'] / (processed_df['trading_volume_change_pct'].abs() + 1e-5)
    )
    
    # Step 3: Categorical Encoding Matrix
    # Encoding string categories cleanly without introducing target leakage
    categorical_cols = ['asset_type', 'news_impact_level', 'risk_label']
    for col in categorical_cols:
        processed_df[col] = processed_df[col].astype('category').cat.codes
        
    # Step 4: Drop unstructured text and raw target indicators to avoid mathematical bias
    unstructured_text_cols = ['asset_symbol', 'news_headline', 'agent_reasoning_summary']
    
    # Define Target variables
    # Quantitative Continuous Target: Price Change Percentage
    y_reg = processed_df['market_price_change_pct']
    
    # Qualitative Class Target: Signal Label (Buy/Sell/Hold)
    y_clf = processed_df['signal_label'].astype('category')
    clf_mapping = dict(enumerate(y_clf.cat.categories))
    y_clf_encoded = y_clf.cat.codes
    
    # Drop targets and non-numeric artifacts from feature set X
    drop_list = unstructured_text_cols + ['market_price_change_pct', 'signal_label']
    X = processed_df.drop(columns=drop_list)
    
    # Step 5: Dual-Model Statistical Assessment Pipeline
    # Part A: Regression Strategy (Predicting Price Action Magnitude)
    X_train_r, X_test_r, y_train_r, y_test_r = train_test_split(
        X, y_reg, test_size=0.2, random_state=42
    )
    
    reg_model = RandomForestRegressor(n_estimators=100, max_depth=8, random_state=42, n_jobs=-1)
    reg_model.fit(X_train_r, y_train_r)
    reg_preds = reg_model.predict(X_test_r)
    
    r2 = r2_score(y_test_r, reg_preds)
    mae = mean_absolute_error(y_test_r, reg_preds)
    
    # Part B: Classification Strategy (Validating Categorical Signal Logic)
    X_train_c, X_test_c, y_train_c, y_test_c = train_test_split(
        X, y_clf_encoded, test_size=0.2, random_state=42
    )
    
    clf_model = RandomForestClassifier(n_estimators=100, max_depth=8, random_state=42, n_jobs=-1)
    clf_model.fit(X_train_c, y_train_c)
    clf_preds = clf_model.predict(X_test_c)
    
    # Step 6: Feature Importance Isolation
    importances = reg_model.feature_importances_
    feature_insights = pd.DataFrame({
        'analyst_feature': X.columns,
        'importance_weight': importances
    }).sort_values(by='importance_weight', ascending=False)
    
    # Step 7: Structuring Output Reports
    print("=== REGRESSION MODEL PERFORMANCE (Price Change) ===")
    print(f"R-Squared (Explaining Variance): {r2:.4f}")
    print(f"Mean Absolute Error: {mae:.4f}")
    print("\n=== CLASSIFICATION REPORT (Signal Label Precision) ===")
    print(classification_report(y_test_c, clf_preds, target_names=[clf_mapping[i] for i in sorted(clf_mapping.keys())]))
    print("\n=== ANALYST FEATURE IMPORTANCE RANKINGS ===")
    print(feature_insights.to_string(index=False))
    
    return reg_model, clf_model, feature_insights

# Execute pipeline on your local verified dataset path
# Function ko active call dene ke liye ye line likhein:
reg_mod, clf_mod, insights = run_alphamind_analytics("finsight_ai_market_signals_dataset.csv")
